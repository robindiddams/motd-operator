#!/bin/bash
# kubectl motd - Set a message-of-the-day via pod names
#
# Installation:
#   ln -s /path/to/motd-operator/hack/kubectl-motd ~/.local/bin/kubectl-motd
#   # or anywhere in your PATH
#
# Usage:
#   kubectl motd <message>              # Set message on default resource
#   kubectl motd -n <namespace> <msg>    # Set message in specific namespace
#   echo "multi\nline" | kubectl motd   # Read message from stdin
#
# The default resource is auto-detected from existing Motd CRs.
# If none exist, creates "my-motd" in the current kubectl namespace.
# Override with -n/--namespace and --name flags.

set -e

# Default values (empty = auto-detect)
NAMESPACE=""
NAME=""

# Help text
show_help() {
  cat << EOF
Usage: kubectl motd [flags] <message>

Set a message-of-the-day displayed via Kubernetes pod names.

Flags:
  -n, --namespace string   Namespace (default: current kubectl namespace)
  --name string           Resource name (default: auto-detect from existing Motd)
  -h, --help              Show this help

Examples:
  kubectl motd Hello World              # Uses first existing Motd, or creates my-motd
  kubectl motd -n my-ns "Hello World"   # Specific namespace
  echo -e "Line 1\nLine 2" | kubectl motd
EOF
}

# Parse flags
ARGS=()
while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)
      show_help
      exit 0
      ;;
    -n|--namespace)
      NAMESPACE="$2"
      shift 2
      ;;
    --namespace=*)
      NAMESPACE="${1#*=}"
      shift
      ;;
    --name)
      NAME="$2"
      shift 2
      ;;
    --name=*)
      NAME="${1#*=}"
      shift
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done
set -- "${ARGS[@]}"

# Auto-detect namespace/name if not specified
if [ -z "$NAMESPACE" ] || [ -z "$NAME" ]; then
  # Find existing Motd resources
  FOUND=$(kubectl get motd -A -o jsonpath='{range .items[*]}{.metadata.namespace}/{.metadata.name}{"\n"}{end}' 2>/dev/null | head -1)
  if [ -n "$FOUND" ]; then
    FOUND_NS=$(echo "$FOUND" | cut -d'/' -f1)
    FOUND_NAME=$(echo "$FOUND" | cut -d'/' -f2)
    [ -z "$NAMESPACE" ] && NAMESPACE="$FOUND_NS"
    [ -z "$NAME" ] && NAME="$FOUND_NAME"
    echo "Using motd/$NAME in $NAMESPACE"
  else
    # No existing resource, use current context namespace or default
    [ -z "$NAMESPACE" ] && NAMESPACE=$(kubectl config view --minify -o jsonpath='{.contexts[].context.namespace}')
    [ -z "$NAMESPACE" ] && NAMESPACE="default"
    [ -z "$NAME" ] && NAME="my-motd"
    echo "No existing Motd found, will create motd/$NAME in $NAMESPACE"
  fi
fi

# Read message from args or stdin
if [ $# -gt 0 ]; then
  MESSAGE="$*"
else
  # Read from stdin (for piping)
  MESSAGE=$(cat)
fi

# Exit if empty message
if [ -z "$MESSAGE" ]; then
  echo "Error: No message provided"
  exit 1
fi

# Escape for JSON (handle quotes, backslashes, newlines)
MESSAGE=$(echo "$MESSAGE" | sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\n' '|' | sed 's/|/\\n/g')

# Try to patch existing resource, create if it doesn't exist
if ! kubectl patch motd "$NAME" -n "$NAMESPACE" --type=merge -p "{\"spec\":{\"message\":\"$MESSAGE\"}}" 2>/dev/null; then
  echo "Creating motd/$NAME in $NAMESPACE"
  kubectl apply -n "$NAMESPACE" -f - << EOF
apiVersion: motd.howcoldismy.beer/v1alpha1
kind: Motd
metadata:
  name: $NAME
spec:
  message: "$MESSAGE"
EOF
fi
